{
  "appName": "CSharpTest",
  "appVersion": "1.0.0",
  "organizationName": "SimpleLambda",
  "appIcon": "app.ico",

  "includeVersionInResultName": true,


  "securityMode": "Integrity",

  "developmentBackendFolder": "backend",
  "developmentFrontendFolder": "frontend",

  "addLicenseToInstaller": true,
  "licenseFile": "license.txt",

  "selfContainedFramework": true,

  "resultFolder": "Results",

  "platforms": {
    "windows": {
      "archs": {
        "x64": {
          "compileCommand": "dotnet publish -c Release -r windows-x64 -o bin",
          "compileDirectory": "bin/Release/net8.0/windows-x64"
        }
      }
    }
  },


  "frontendInitialHTML": "index.html",

  "window": {
    "title": "CSharpTest",
    "width": 800,
    "height": 600,
    "minWidth": 400,
    "minHeight": 300,
    "maxWidth": 1920,
    "maxHeight": 1080
  }
}