{
  "appName": "CSharpTest",
  "appVersion": "1.0.0",
  "organizationName": "SimpleLambda",
  "appIcon": "app.ico",

  "includeVersionInResultName": true,


  "securityMode": "Hardened",
  "ipcTransport": "NamedPipe",

  "developmentBackendFolder": "Examples/CSharp/backend",
  "developmentFrontendFolder": "Examples/CSharp/frontend",

  "addLicenseToInstaller": true,
  "licenseFile": "license.txt",

  "selfContainedFramework": true,

  "resultFolder": "Results",

  "platforms": {
    "windows": {
      "archs": {
        "x64": {
          "compileCommand": "dotnet publish Backend.csproj -c Release -r win-x64 --self-contained false -o bin",
          "compileDirectory": "bin"
        }
      }
    }
  },


  "frontendInitialHTML": "index.html",

  "window": {
    "title": "CSharpTest",
    "width": 800,
    "height": 600,
    "minWidth": 400,
    "minHeight": 300,
    "maxWidth": 1920,
    "maxHeight": 1080
  }
}
