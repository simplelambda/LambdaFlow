{
  "appName": "LambdaFlowJava",
  "appVersion": "1.0.0",
  "organizationName": "SimpleLambda",
  "appIcon": "app.ico",

  "securityMode": "Hardened",
  "ipcTransport": "NamedPipe",

  "developmentBackendFolder": "backend",
  "developmentFrontendFolder": "frontend",
  "resultFolder": "Results",

  "frontendInitialHTML": "index.html",

  "platforms": {
    "windows": {
      "archs": {
        "x64": {
          "compileCommand": "mvn -q -DskipTests package",
          "compileDirectory": "target",
          "runCommand": "java",
          "runArgs": ["-jar", "Backend.jar"]
        }
      }
    }
  },

  "window": {
    "title": "LambdaFlow Java",
    "width": 1000,
    "height": 700,
    "minWidth": 640,
    "minHeight": 480,
    "maxWidth": 0,
    "maxHeight": 0
  }
}
