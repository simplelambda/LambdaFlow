{
  "name": "lambdaflow",
  "displayName": "LambdaFlow",
  "description": "Build desktop apps with a web frontend and any backend language.",
  "version": "1.2.0",
  "publisher": "simplelambda",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./out/extension",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lambdaflow-sidebar",
          "title": "LambdaFlow",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "lambdaflow-sidebar": [
        {
          "type": "webview",
          "id": "lambdaflow.sidebar",
          "name": "LambdaFlow"
        }
      ]
    },
    "commands": [
      {
        "command": "lambdaflow.newProject",
        "title": "New Project",
        "category": "LambdaFlow",
        "icon": "$(add)"
      },
      {
        "command": "lambdaflow.buildProject",
        "title": "Build",
        "category": "LambdaFlow",
        "icon": "$(gear)"
      },
      {
        "command": "lambdaflow.openConfig",
        "title": "Edit Configuration",
        "category": "LambdaFlow",
        "icon": "$(settings-gear)"
      },
      {
        "command": "lambdaflow.runProject",
        "title": "Build & Run",
        "category": "LambdaFlow",
        "icon": "$(debug-start)"
      },
      {
        "command": "lambdaflow.debugProject",
        "title": "Build & Debug",
        "category": "LambdaFlow",
        "icon": "$(debug-alt)"
      }
    ],
    "customEditors": [
      {
        "viewType": "lambdaflow.configEditor",
        "displayName": "LambdaFlow Config Editor",
        "selector": [
          {
            "filenamePattern": "config.json"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "lambdaflow.newProject"   },
        { "command": "lambdaflow.buildProject" },
        { "command": "lambdaflow.openConfig"   },
        { "command": "lambdaflow.runProject"   },
        { "command": "lambdaflow.debugProject" }
      ],
      "view/title": [
        {
          "command": "lambdaflow.runProject",
          "when": "view == lambdaflow.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "lambdaflow.debugProject",
          "when": "view == lambdaflow.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "lambdaflow.buildProject",
          "when": "view == lambdaflow.sidebar",
          "group": "navigation@3"
        },
        {
          "command": "lambdaflow.newProject",
          "when": "view == lambdaflow.sidebar",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "LambdaFlow",
      "properties": {
        "lambdaflow.frameworkPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the LambdaFlow framework source directory.",
          "scope": "machine"
        }
      }
    }
  },
  "scripts": {
    "compile": "node ./node_modules/typescript/lib/tsc.js -p ./",
    "watch": "node ./node_modules/typescript/lib/tsc.js -watch -p ./",
    "package": "npx vsce package --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.9.3"
  }
}
