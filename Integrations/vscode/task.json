{
  "version": "1.0.0",
  "tasks": [
    {
      "label": "build Host.Windows",
      "command": "dotnet",
      "type": "process",
      "args": [ "build", "src/LambdaFlow.Host.Windows/LambdaFlow.Host.Windows.csproj", "-c", "Debug" ],
      "group": "build"
    },
    {
      "label": "publish Host.Windows win-x64",
      "command": "dotnet",
      "type": "process",
      "args": [ "publish", "src/LambdaFlow.Host.Windows/LambdaFlow.Host.Windows.csproj", "-c", "Release", "-r", "win-x64", "--self-contained", "true" ]
    }
  ]
}
